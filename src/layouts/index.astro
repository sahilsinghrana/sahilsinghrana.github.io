---
import { Head } from "astro-capo";
import { Font } from "astro:assets";

import Header from "@components/Header/index.astro";
import Footer from "@components/Footer/index.astro";
import Moon from "@components/General/Moon/index.astro";

import OgMeta from "./Metas/OgMeta.astro";
import DefaultMeta from "./Metas/DefaultMeta.astro";
import GtagHeadScripts from "./Metas/GtagHeadScripts.astro";
import DescriptionMeta from "./Metas/DescriptionMeta.astro";

const { title, description, keywords, className } = Astro.props;

import "@styles/global.scss";

// import "./test.scss";
---

<html lang="en">
  <Head>
    <Font cssVariable="--font-manrope" />
    <Font cssVariable="--font-raleway" />
    <Font cssVariable="--font-roboto" />
    <Font cssVariable="--font-inter" />
    <DefaultMeta />
    <GtagHeadScripts />
    <OgMeta title={title} description={description} />
    <DescriptionMeta
      title={title}
      description={description}
      keywords={keywords}
    />

    <title>{title}</title>
  </Head>

  <body>
    <Header />
    <Moon />
    <main>
      <div class={"content " + className}>
        <slot />
      </div>
    </main>
    <Footer />
  </body>
</html>

<script>
  import dateBasedClassInjector, {
    dateBasedJsInjector,
  } from "src/scripts/dateBasedClassInjector";
  import { initStarAnimation } from "src/scripts/starAnimation";

  // dateBasedClassInjector(17, 6, "tulips");
  // dateBasedClassInjector(17, 6, "colorful");
  // dateBasedClassInjector(17, 6, "fireworks");
  // dateBasedJsInjector(17, 6, "tulips");
  // dateBasedJsInjector(17, 6, "fireworks");

  dateBasedClassInjector(16, 1, "tulips");
  dateBasedJsInjector(16, 1, "tulips");

  dateBasedClassInjector(17, 1, "tulips");
  dateBasedJsInjector(17, 1, "tulips");

  dateBasedClassInjector(20, 1, "tulips");
  dateBasedJsInjector(20, 1, "tulips");

  dateBasedClassInjector(23, 1, "tulips");
  dateBasedJsInjector(23, 1, "tulips");

  dateBasedClassInjector(24, 1, "tulips");
  dateBasedJsInjector(24, 1, "tulips");

  dateBasedClassInjector(25, 1, "gray");

  dateBasedClassInjector(28, 11, "colorful");
  dateBasedClassInjector(28, 11, "tulips");
  dateBasedClassInjector(28, 11, "fireworks");
  dateBasedJsInjector(28, 11, "tulips");
  dateBasedJsInjector(28, 11, "fireworks");

  initStarAnimation();
</script>
